@page "/admin-dashboard"
@using Schronisko.Shared.Entities
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers 

@* ZABEZPIECZENIE: Strona dostępna TYLKO dla Admina i Pracownika. *@
@* Jeśli wejdzie tu zwykły User, zostanie wyrzucony (zazwyczaj na stronę NotAuthorized lub Login). *@
@attribute [Authorize(Roles = "Admin,Employee")]

@inject HttpClient Http
@inject IJSRuntime JS

<div class="container mt-4">
    <h2 class="mb-4">Panel Zarządzania</h2>

    @* === SEKCJA 1: KAFELKI ZE STATYSTYKAMI === *@
    @* Te dane pochodzą z Twojego StatsController (który używa procedury SQL). *@
    @if (stats != null)
    {
        <div class="row mb-5">
            @* Kafelek: Zwierzęta do adopcji *@
            <div class="col-md-4">
                <div class="card text-white bg-success mb-3 shadow">
                    <div class="card-header">🐶 Do adopcji</div>
                    <div class="card-body">
                        <h1 class="card-title text-center display-4 fw-bold">@stats.AvailableCount</h1>
                        <p class="card-text text-center">Dostępnych zwierząt</p>
                    </div>
                </div>
            </div>

            @* Kafelek: Udane adopcje *@
            <div class="col-md-4">
                <div class="card text-white bg-primary mb-3 shadow">
                    <div class="card-header">🏠 Znalazło dom</div>
                    <div class="card-body">
                        <h1 class="card-title text-center display-4 fw-bold">@stats.AdoptedCount</h1>
                        <p class="card-text text-center">Szczęśliwych adopcji</p>
                    </div>
                </div>
            </div>

            @* Kafelek: Oczekujące wnioski (Decyzje) *@
            <div class="col-md-4">
                <div class="card text-dark bg-warning mb-3 shadow">
                    <div class="card-header">⏳ Decyzje do podjęcia</div>
                    <div class="card-body">
                        <h1 class="card-title text-center display-4 fw-bold">@stats.PendingRequests</h1>
                        <p class="card-text text-center">Oczekujących wniosków</p>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        @* Spinner ładowania, zanim dane przyjdą z API *@
        <div class="d-flex align-items-center mb-4">
            <div class="spinner-border text-secondary me-2" role="status"></div>
            <span>Ładowanie raportów...</span>
        </div>
    }

    @* Powiadomienia o sukcesie/błędzie operacji *@
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-info">@message</div>
    }

    @* === SEKCJA 2: TABELA WNIOSKÓW === *@
    <h4 class="mb-3">Lista Wniosków Adopcyjnych</h4>

    @if (requests == null)
    {
        <div class="spinner-border text-primary" role="status"></div>
        <p>Ładowanie wniosków...</p>
    }
    else if (requests.Count == 0)
    {
        <div class="alert alert-warning">Brak złożonych wniosków.</div>
    }
    else
    {
        <table class="table table-striped table-hover shadow-sm">
            <thead class="bg-dark text-white">
                <tr>
                    <th>Data</th>
                    <th>Zwierzę</th>
                    <th>Kandydat</th>
                    <th>Powód adopcji</th>
                    <th>Status</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in requests)
                {
                    <tr>
                        <td>@req.RequestDate.ToShortDateString()</td>
                        
                        @* Kolumna: ZWIERZĘ *@
                        <td>
                            @* Sprawdzamy null, bo pies mógł zostać usunięty z bazy, a wniosek został *@
                            @if (req.Animal != null)
                            {
                                <strong>@req.Animal.Name</strong> <span class="text-muted">(@req.Animal.Species)</span>
                            }
                            else
                            {
                                <span class="text-muted text-decoration-line-through">(Zwierze usunięte)</span>
                            }
                        </td>

                        @* Kolumna: KANDYDAT *@
                        <td>
                            @if (req.User != null)
                            {
                                <div>👤 <strong>@req.User.Username</strong></div>
                                <small class="text-muted">@req.User.Email</small>
                            }
                            else
                            {
                                <span class="text-danger">Nieznany (ID: @req.UserId)</span>
                            }
                        </td>

                        <td>@req.Reason</td>

                        @* Kolumna: STATUS (Kolorowa etykieta) *@
                        <td>
                            <span class="badge @GetBadgeClass(req.Status)">@req.Status</span>
                        </td>

                        @* Kolumna: AKCJE (Przyciski) *@
                        <td>
                            @* Pokazujemy przyciski TYLKO jeśli wniosek czeka na decyzję *@
                            @if (req.Status == "Oczekujący" || req.Status == "Pending")
                            {
                                <button class="btn btn-success btn-sm me-2" @onclick='() => UpdateStatus(req.Id, "Zatwierdzony")'>✅ Zatwierdź</button>
                                <button class="btn btn-danger btn-sm" @onclick='() => UpdateStatus(req.Id, "Odrzucony")'>❌ Odrzuć</button>
                            }
                            else
                            {
                                <span class="text-muted small">Rozpatrzony</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<AdoptionRequest>? requests;
    private ShelterStatsDto? stats; // Zmienna na raporty (statystyki)
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    // =============================================================
    // ŁADOWANIE DANYCH (Wywoływane przy starcie i po każdej zmianie)
    // =============================================================
    private async Task LoadData()
    {
        try
        {
            // 1. Autoryzacja: Pobieramy token z pamięci przeglądarki.
            // Musimy go dodać do nagłówka, bo endpointy /api/stats i /api/requests są chronione!
            var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            // 2. Pobierz listę wszystkich wniosków (AdoptionRequestsController)
            requests = await Http.GetFromJsonAsync<List<AdoptionRequest>>("api/adoptionrequests");

            // 3. Pobierz STATYSTYKI (StatsController -> Procedura SQL)
            // Dzięki temu kafelki na górze strony pokażą aktualne liczby.
            stats = await Http.GetFromJsonAsync<ShelterStatsDto>("api/stats");
        }
        catch (Exception ex)
        {
            message = $"Błąd ładowania danych: {ex.Message}";
        }
    }

    // =============================================================
    // ZMIANA STATUSU (Zatwierdź / Odrzuć)
    // =============================================================
    private async Task UpdateStatus(int id, string status)
    {
        try
        {
            // Wysyłamy zapytanie PUT do API z nowym statusem (np. "Zatwierdzony")
            var response = await Http.PutAsJsonAsync($"api/adoptionrequests/{id}", status);

            if (response.IsSuccessStatusCode)
            {
                message = $"Status zmieniony na: {status}";
                
                // KLUCZOWE: Ponowne załadowanie danych!
                // Dlaczego? Bo jeśli zatwierdziliśmy wniosek, to:
                // 1. Status wniosku się zmienił (tabela musi się odświeżyć).
                // 2. Status psa zmienił się na "Adoptowany" (statystyki na kafelkach muszą się zmienić!).
                await LoadData();
            }
            else
            {
                message = "Błąd aktualizacji statusu.";
            }
        }
        catch (Exception ex)
        {
            message = $"Błąd połączenia: {ex.Message}";
        }
    }

    // Pomocnicza funkcja do kolorowania statusów
    private string GetBadgeClass(string status)
    {
        return status switch
        {
            "Zatwierdzony" => "bg-success", // Zielony
            "Approved" => "bg-success",
            "Odrzucony" => "bg-danger",     // Czerwony
            "Rejected" => "bg-danger",
            "Oczekujący" => "bg-warning text-dark", // Żółty
            "Pending" => "bg-warning text-dark",
            _ => "bg-secondary"             // Szary (nieznany)
        };
    }

    // Klasa DTO (Data Transfer Object) - musi pasować do tego, co zwraca StatsController
    public class ShelterStatsDto
    {
        public int AvailableCount { get; set; }
        public int AdoptedCount { get; set; }
        public int PendingRequests { get; set; }
    }
}