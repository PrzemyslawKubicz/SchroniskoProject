@page "/my-adoptions"
@using Schronisko.Shared.Entities
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers

@* ZABEZPIECZENIE: *@
@* Atrybut [Authorize] sprawia, że jeśli wejdzie tu ktoś niezalogowany, *@
@* Blazor automatycznie przekieruje go do strony logowania (lub pokaże komunikat NotAuthorized). *@
@attribute [Authorize] 

@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="container mt-4">
    <h3>📂 Moje wnioski adopcyjne</h3>

    @* 1. STAN ŁADOWANIA: requests == null *@
    @if (requests == null)
    {
        <p>Ładowanie...</p>
    }
    @* 2. STAN PUSTY: requests.Count == 0 *@
    else if (requests.Count == 0)
    {
        <div class="alert alert-info">Nie złożyłeś jeszcze żadnych wniosków. <a href="">Wróć na stronę główną</a></div>
    }
    @* 3. STAN DANYCH: Wyświetlamy tabelę *@
    else
    {
        <table class="table table-hover mt-3">
            <thead class="table-light">
                <tr>
                    <th>Data</th>
                    <th>Zwierzak</th>
                    <th>Twój powód</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in requests)
                {
                    <tr>
                        <td>@req.RequestDate.ToShortDateString()</td>
                        <td>
                            @if (req.Animal != null)
                            {
                                <strong>@req.Animal.Name</strong> <span class="text-muted">(@req.Animal.Species)</span>
                            }
                            else
                            {
                                @* Jeśli pies został usunięty z bazy, ale wniosek został w archiwum *@
                                <span>(Zwierzak usunięty)</span>
                            }
                        </td>
                        <td>@req.Reason</td>
                        <td>
                            @* Kolorowanie statusu (Zielony/Czerwony/Żółty) *@
                            <span class="badge @GetBadgeClass(req.Status)">@req.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private List<AdoptionRequest>? requests;

    protected override async Task OnInitializedAsync()
    {
        // 1. Pobieramy token z przeglądarki (Session Storage)
        // Musimy to zrobić ręcznie, aby dołączyć go do zapytania HTTP.
        var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");
        
        // Zabezpieczenie: Jeśli token zniknął (np. wygasła sesja), wyrzucamy do logowania
        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("login");
            return;
        }

        // 2. Ustawiamy nagłówek "Authorization: Bearer <token>"
        // Dzięki temu API będzie wiedziało, KIM jesteśmy (wyciągnie nasze ID z tokena).
        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        // 3. Pobieramy "Moje Wnioski"
        // Zwróć uwagę na końcówkę URL: "api/adoptionrequests/my".
        // To specjalna metoda w kontrolerze, która używa User.FindFirst(...) 
        // żeby zwrócić tylko te rekordy, które należą do nas.
        try
        {
            requests = await Http.GetFromJsonAsync<List<AdoptionRequest>>("api/adoptionrequests/my");
        }
        catch (Exception)
        {
            // Jeśli token jest nieprawidłowy (np. stary), serwer zwróci 401 Unauthorized.
            // Warto wtedy przekierować do logowania.
            Navigation.NavigateTo("login");
        }
    }

    // Pomocnicza metoda do stylów Bootstrapa (Kolorki)
    private string GetBadgeClass(string status)
    {
        return status switch
        {
            "Zatwierdzony" => "bg-success", // Zielony
            "Approved" => "bg-success",
            "Odrzucony" => "bg-danger",     // Czerwony
            "Rejected" => "bg-danger",
            _ => "bg-warning text-dark"     // Żółty (Oczekujący)
        };
    }
}