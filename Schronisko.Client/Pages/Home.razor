@page "/"
@using Schronisko.Shared.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Schronisko - Strona Główna</PageTitle>

<div class="hero-section text-center">
    <h1 class="display-3 fw-bold">Witaj na stronie schroniska! 🐶🐱</h1>
    <p class="lead fs-4">Twój nowy najlepszy przyjaciel czeka na Ciebie.</p>
    <a href="#animals-list" class="btn btn-primary btn-lg mt-3">Znajdź zwierzaka</a>
</div>

<div id="animals-list"></div>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @(isError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @message
        <button type="button" class="btn-close" @onclick="() => message = string.Empty"></button>
    </div>
}

<div class="row mb-4 justify-content-center">
    <div class="col-md-8">
        <div class="input-group shadow-sm">
            <span class="input-group-text bg-white border-0">🔍</span>
            <input type="text" class="form-control border-0" placeholder="Szukaj po imieniu..."
                   @bind="searchText" @bind:event="oninput" @onkeyup="FilterAnimals" />

            <select class="form-select border-0" style="max-width: 200px; border-left: 1px solid #eee;" @onchange="OnSpeciesChanged">
                <option value="">Wszystkie</option>
                <option value="Pies">Pies</option>
                <option value="Kot">Kot</option>
                <option value="Inny">Inny</option>
            </select>
        </div>
    </div>
</div>

@if (filteredAnimals == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Ładowanie zwierzaków...</p>
    </div>
}
else if (filteredAnimals.Count == 0)
{
    <div class="alert alert-warning text-center">Nie znaleziono zwierząt spełniających kryteria.</div>
}
else
{
    <div class="row">
        @foreach (var animal in filteredAnimals)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm hover-shadow">
                    <img src="@animal.ImageUrl" class="card-img-top" alt="@animal.Name"
                         style="height: 250px; object-fit: cover;"
                         onerror="this.src='/images/default.png'">

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="card-title mb-0 fw-bold">@animal.Name</h5>
                            <span class="badge @GetStatusBadge(animal.Status)">@animal.Status</span>
                        </div>

                        <h6 class="card-subtitle mb-2 text-muted">@animal.Species • @animal.Age lat(a)</h6>

                        <p class="card-text text-primary small mb-1">
                            W schronisku:
                            <strong>
                                @if (animal.DaysInShelter == 0)
                                {
                                    <span>Dzisiaj dołączył!</span>
                                }
                                else
                                {
                                    <span>@animal.DaysInShelter dni</span>
                                }
                            </strong>
                        </p>
                        <p class="card-text text-muted">@animal.Description</p>

                        <div class="mt-auto pt-3">

                            <AuthorizeView Roles="Admin,Employee">
                                <a href="edit-animal/@animal.Id" class="btn btn-outline-warning btn-sm w-100 mb-2">
                                    Edytuj
                                </a>
                            </AuthorizeView>

                            <AuthorizeView Roles="Admin">
                                <button class="btn btn-outline-danger btn-sm w-100 mb-2" @onclick="() => DeleteAnimal(animal.Id)">
                                    Usuń
                                </button>
                            </AuthorizeView>

                            <AuthorizeView Roles="User">
                                @if (animal.Status == "Do adopcji")
                                {
                                    <button class="btn btn-primary w-100 shadow-sm" @onclick="() => AdoptAnimal(animal.Id)">
                                        ❤️ Adoptuj mnie!
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-100" disabled>Niedostępny</button>
                                }
                            </AuthorizeView>

                            <AuthorizeView>
                                <NotAuthorized>
                                    <a href="login" class="btn btn-outline-primary w-100">Zaloguj się, aby zaadoptować</a>
                                </NotAuthorized>
                            </AuthorizeView>

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Animal>? allAnimals;
    private List<Animal>? filteredAnimals;

    private string message = "";
    private bool isError = false;
    private string searchText = "";
    private string selectedSpecies = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAnimals();
    }

    private async Task LoadAnimals()
    {
        try
        {
            allAnimals = await Http.GetFromJsonAsync<List<Animal>>("api/animals");
            filteredAnimals = allAnimals;
        }
        catch (Exception ex)
        {
            message = "Błąd pobierania danych.";
            isError = true;
        }
    }

    private void FilterAnimals()
    {
        if (allAnimals == null) return;
        var query = allAnimals.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
            query = query.Where(a => a.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));

        if (!string.IsNullOrWhiteSpace(selectedSpecies))
            query = query.Where(a => a.Species == selectedSpecies);

        filteredAnimals = query.ToList();
    }

    private void OnSpeciesChanged(ChangeEventArgs e)
    {
        selectedSpecies = e.Value?.ToString() ?? "";
        FilterAnimals();
    }

    private async Task AdoptAnimal(int animalId)
    {
        var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");

        if (string.IsNullOrEmpty(token))
        {
            Navigation.NavigateTo("login");
            return;
        }

        string reason = await JS.InvokeAsync<string>("prompt", "Dlaczego chcesz adoptować tego zwierzaka?");
        if (string.IsNullOrWhiteSpace(reason)) return;

        try
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            var request = new AdoptionRequest
            {
                AnimalId = animalId,
                Reason = reason,
                Status = "Oczekujący",
                RequestDate = DateTime.Now
            };

            var response = await Http.PostAsJsonAsync("api/adoptionrequests", request);

            if (response.IsSuccessStatusCode)
            {
                message = "🎉 Wniosek wysłany! Czekaj na decyzję admina.";
                isError = false;

                var animal = allAnimals?.FirstOrDefault(a => a.Id == animalId);
                if (animal != null) animal.Status = "Oczekujący";
                FilterAnimals();
            }
            else
            {
                // Obsługa błędu 403 Forbidden (gdyby jednak Admin próbował kliknąć)
                if (response.StatusCode == System.Net.HttpStatusCode.Forbidden)
                {
                    message = "Personel nie może składać wniosków adopcyjnych (zaloguj się jako User).";
                    isError = true;
                }
                else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                {
                    Navigation.NavigateTo("login");
                }
                else
                {
                    message = "Błąd wysyłania wniosku.";
                    isError = true;
                }
            }
        }
        catch (Exception ex)
        {
            message = $"Błąd: {ex.Message}";
            isError = true;
        }
    }

    private async Task DeleteAnimal(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Czy na pewno chcesz usunąć tego zwierzaka?");
        if (!confirmed) return;

        var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");
        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        var response = await Http.DeleteAsync($"api/animals/{id}");

        if (response.IsSuccessStatusCode)
        {
            message = "Zwierzak usunięty.";
            isError = false;

            var itemToRemove = allAnimals?.FirstOrDefault(a => a.Id == id);
            if (itemToRemove != null)
            {
                allAnimals?.Remove(itemToRemove);
                FilterAnimals();
            }
        }
        else
        {
            message = "Błąd usuwania.";
            isError = true;
        }
    }

    private string GetStatusBadge(string status)
    {
        return status switch
        {
            "Do adopcji" => "bg-success",
            "Oczekujący" => "bg-warning text-dark",
            "Adoptowany" => "bg-secondary",
            "Zaadoptowany" => "bg-secondary",
            _ => "bg-light text-dark border"
        };
    }
}