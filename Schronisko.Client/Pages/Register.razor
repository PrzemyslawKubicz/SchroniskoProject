@page "/register"
@inject HttpClient Http
@inject NavigationManager Navigation
@using Schronisko.Shared.Entities

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow">
        <div class="card-body">
            <h3 class="text-center mb-4">Rejestracja</h3>

            @* Wyświetlanie błędów (np. "Taki e-mail już istnieje") *@
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @* Formularz rejestracji *@
            <EditForm Model="user" OnValidSubmit="HandleRegister">
                @* Uruchamia walidację na podstawie adnotacji w klasie User (np. [Required]) *@
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Nazwa użytkownika</label>
                    <InputText @bind-Value="user.Username" class="form-control" placeholder="Np. JanKowalski" />
                </div>

                <div class="mb-3">
                    <label>Adres E-mail</label>
                    <InputText @bind-Value="user.Email" type="email" class="form-control" placeholder="jan@przyklad.pl" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Hasło</label>
                    <div class="input-group">
                        @* LOGIKA HASŁA: *@
                        @* Zmienna 'password' jest tymczasowa, przepisujemy ją do modelu dopiero przy wysyłce *@
                        @* type="@(...)" zmienia input z kropek (password) na tekst (text) *@
                        <InputText @bind-Value="password" type="@(showPassword ? "text" : "password")" class="form-control form-control-lg" />

                        <button class="btn btn-outline-secondary" type="button" @onclick="TogglePassword">
                            @(showPassword ? "👁️" : "🔒")
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Zarejestruj się</button>
            </EditForm>

            <div class="mt-3 text-center">
                <a href="login">Masz już konto? Zaloguj się</a>
            </div>
        </div>
    </div>
</div>

@code {
    // --- LOKALNE DTO (Data Transfer Object) ---
    // Dlaczego to tu jest?
    // Oryginalna klasa 'User' ma pole PasswordHash (zaszyfrowane).
    // My w formularzu potrzebujemy zwykłego pola 'Password' (tekst jawny).
    // Dziedziczymy po User, żeby zachować pola Username/Email i dodajemy Password.
    public class UserDto : User
    {
        public string Password { get; set; } = string.Empty;
    }

    private UserDto user = new UserDto();
    private string password = ""; // Zmienna pomocnicza do wiązania z inputem
    private string errorMessage = "";

    // Zmienna do sterowania ikoną oka i typem pola hasła
    private bool showPassword = false;

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private async Task HandleRegister()
    {
        // Przepisujemy hasło z inputa do obiektu DTO
        user.Password = password;

        // Wysyłamy dane do AuthController.cs -> metoda Register
        var response = await Http.PostAsJsonAsync("api/auth/register", user);

        if (response.IsSuccessStatusCode)
        {
            // Sukces -> Przekieruj do logowania
            Navigation.NavigateTo("login");
        }
        else
        {
            // Błąd -> Wyświetl komunikat z API (np. "Użytkownik już istnieje")
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }
}