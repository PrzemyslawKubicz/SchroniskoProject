@page "/logs"
@using Schronisko.Shared.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http

<PageTitle>Logi Systemowe</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📋 Dziennik Zdarzeń (Logi)</h2>
        <button class="btn btn-outline-primary" @onclick="LoadLogs">🔄 Odśwież</button>
    </div>

    @if (logs == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p>Ładowanie historii...</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="bg-light">
                    <tr>
                        <th>Data</th>
                        <th>Użytkownik (Relacja)</th>
                        <th>Email (Kopia)</th>
                        <th>Akcja / Błąd</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in logs)
                    {
                        <tr>
                            <td class="text-muted small">
                                @log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")
                            </td>
                            <td>
                                @if (log.User != null)
                                {
                                    // Dowód na działanie relacji 1:N
                                    <span class="badge bg-success">👤 @log.User.Username</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">🤖 System / Anonim</span>
                                }
                            </td>
                            <td class="small text-muted">@log.UserEmail</td>
                            <td>
                                @if (log.Action.Contains("Błąd") || log.Action.Contains("Error"))
                                {
                                    <span class="text-danger fw-bold">@log.Action</span>
                                }
                                else
                                {
                                    <span>@log.Action</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Log>? logs;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try
        {
            logs = await Http.GetFromJsonAsync<List<Log>>("api/logs");
        }
        catch (Exception)
        {
            // Ignorujemy błędy połączenia dla estetyki demo
        }
    }
}