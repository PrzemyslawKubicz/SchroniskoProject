@* [ZMIANA 1] Dwie ścieżki: Jedna do dodawania (bez ID), druga do edycji (z ID) *@
@page "/edit-animal"
@page "/edit-animal/{Id:int}"

@using Schronisko.Shared.Entities
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers

@attribute [Authorize(Roles = "Admin,Employee")]

@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

@* [ZMIANA 2] Dynamiczny tytuł strony *@
<PageTitle>@(Id == null ? "Dodaj Zwierzaka" : "Edytuj Zwierzaka")</PageTitle>

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow border-0">
        @* [ZMIANA 3] Dynamiczny nagłówek karty (Zielony dla nowego, Żółty dla edycji) *@
        <div class="card-header @(Id == null ? "bg-success text-white" : "bg-warning text-dark") text-center py-3">
            <h4 class="mb-0 fw-bold">@(Id == null ? "Dodawanie Nowego Zwierzaka" : "Edycja Zwierzaka")</h4>
        </div>
        <div class="card-body p-4">

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @* Jeśli ładujemy dane (tylko przy edycji) *@
            @if (Id != null && animal == null)
            {
                <div class="text-center">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p>Ładowanie danych...</p>
                </div>
            }
            else
            {
                @* Zmieniono nazwę funkcji na HandleSubmit (bo obsługuje i update, i create) *@
                <EditForm Model="animal" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Imię:</label>
                        <InputText class="form-control" @bind-Value="animal.Name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Gatunek:</label>
                        <InputSelect class="form-select" @bind-Value="animal.Species">
                            <option value="Pies">Pies</option>
                            <option value="Kot">Kot</option>
                            <option value="Inny">Inny</option>
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Status:</label>
                        <InputSelect class="form-select" @bind-Value="animal.Status">
                            <option value="Do adopcji">Do adopcji</option>
                            <option value="Oczekujący">Oczekujący</option>
                            <option value="Zaadoptowany">Zaadoptowany</option>
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Wiek (lat):</label>
                        <InputNumber class="form-control" @bind-Value="animal.Age" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Opis:</label>
                        <InputTextArea class="form-control" @bind-Value="animal.Description" rows="4" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Zdjęcie:</label>
                        <InputFile OnChange="HandleImageUpload" class="form-control" accept="image/png, image/jpeg, image/jpg" />
                        <small class="text-muted">Max 5 MB. @(Id != null ? "Zostaw puste, aby zachować obecne." : "")</small>

                        @if (!string.IsNullOrEmpty(animal.ImageUrl))
                        {
                            <div class="text-center mt-3">
                                <p class="mb-1 text-muted small">Podgląd:</p>
                                <img src="@animal.ImageUrl" class="img-thumbnail" style="max-height: 200px;"
                                     onerror="this.src='/images/default.png'" />
                            </div>
                        }
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn @(Id == null ? "btn-success" : "btn-warning")">
                            💾 @(Id == null ? "Dodaj Zwierzaka" : "Zapisz Zmiany")
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="GoBack">Anuluj</button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    // [ZMIANA 4] Id jest teraz nullable (int?), bo przy dodawaniu go nie ma
    [Parameter]
    public int? Id { get; set; }

    // Przy dodawaniu tworzymy nowy obiekt, żeby formularz nie był null
    private Animal animal = new Animal { Species = "Pies", Status = "Do adopcji" };

    private string errorMessage = "";
    private long maxFileSize = 1024 * 1024 * 5;

    protected override async Task OnInitializedAsync()
    {
        // [ZMIANA 5] Pobieramy dane TYLKO jeśli mamy ID (czyli edycja)
        if (Id != null)
        {
            try
            {
                animal = await Http.GetFromJsonAsync<Animal>($"api/animals/{Id}");
            }
            catch (Exception)
            {
                await JS.InvokeVoidAsync("alert", "Nie znaleziono zwierzaka!");
                Navigation.NavigateTo("/");
            }
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            var format = "image/jpeg";
            var resizedImage = await file.RequestImageFileAsync(format, 600, 600);
            var buffer = new byte[resizedImage.Size];
            await resizedImage.OpenReadStream(maxFileSize).ReadAsync(buffer);
            var base64Data = Convert.ToBase64String(buffer);

            if (animal != null)
            {
                animal.ImageUrl = $"data:{format};base64,{base64Data}";
            }
            errorMessage = "";
        }
        catch (Exception ex)
        {
            errorMessage = $"Błąd zdjęcia: {ex.Message}";
        }
    }

    // [ZMIANA 6] Logika rozdzielająca POST (Dodaj) i PUT (Edytuj)
    private async Task HandleSubmit()
    {
        // Zabezpieczenie przed brakiem zdjęcia
        if (string.IsNullOrEmpty(animal.ImageUrl)) animal.ImageUrl = "images/default.png";

        var token = await JS.InvokeAsync<string>("sessionStorage.getItem", "authToken");
        Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

        HttpResponseMessage response;

        if (Id == null)
        {
            // === SCENARIUSZ 1: DODAWANIE (CREATE) ===
            response = await Http.PostAsJsonAsync("api/animals", animal);
        }
        else
        {
            // === SCENARIUSZ 2: EDYCJA (UPDATE) ===
            response = await Http.PutAsJsonAsync($"api/animals/{Id}", animal);
        }

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            errorMessage = "Wystąpił błąd podczas zapisywania. Sprawdź dane.";
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}